{
  "name": "sifup",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:safe": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-safe.ps1",
    "dev:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/node-doctor.ps1",
    "dev:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-node-dev.ps1",
    "dev:stop:dry": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-node-dev.ps1 -DryRun",
    "test": "tsx --test src/lib/parser.test.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:schema": "node scripts/run-sql.mjs db/schema.sql",
    "db:seed": "node scripts/run-sql.mjs db/seed.sql",
    "db:setup": "npm run db:schema && npm run db:seed"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
